# Copy to .env and fill in.

# ── Zoho OAuth (Self Client app: https://api-console.zoho.in) ──────────────
# Scope to grant when generating refresh token:
#   Desk.tickets.CREATE,Desk.contacts.CREATE,Desk.contacts.READ
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOHO_REFRESH_TOKEN=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Zoho Desk org + department ─────────────────────────────────────────────
# orgId: Desk → Setup → Developer Space → API → orgId
# departmentId: Setup → General → Departments → click one → URL has /dept/<id>
ZOHO_ORG_ID=123456789
ZOHO_DEPARTMENT_ID=987654321000000001

# ── Zoho regional endpoints ────────────────────────────────────────────────
# India: https://accounts.zoho.in + https://desk.zoho.in
# US:    https://accounts.zoho.com + https://desk.zoho.com
# EU:    https://accounts.zoho.eu + https://desk.zoho.eu
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_DESK_URL=https://desk.zoho.in

# ── Chatwoot API (used to assign teams) ────────────────────────────────────
# Profile picture (top right in Chatwoot) → Profile Settings → bottom → Access Token
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHATWOOT_ACCOUNT_ID=1

# Optional: leave blank to disable signature check
CHATWOOT_WEBHOOK_SECRET=

# ── OpenAI (for team + email-type + escalation classification) ─────────────
# https://platform.openai.com/api-keys
#
# PRIVACY NOTE: full inbound message bodies (which may contain PII —
# customer names, emails, phone numbers, order details) are sent to
# OpenAI for classification. Review your data-processing agreement and
# disclose this in your privacy policy. Set OPENAI_DATA_RETENTION to
# zero-retention via the OpenAI dashboard if your DPA requires it.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ── Chatwoot team IDs ──────────────────────────────────────────────────────
# Find them with:
#   curl -H "api_access_token: $CHATWOOT_API_TOKEN" \
#        http://localhost:3000/api/v1/accounts/1/teams
# (Returns JSON list with id + name for each team.)
TEAM_ID_LEGAL=1
TEAM_ID_MARKETING=2
TEAM_ID_HR=3
TEAM_ID_SUPPORT=4

# ── Google Reviews (OPTIONAL — leave disabled until GBP API access granted) ─
# See GOOGLE_REVIEWS_SETUP.md for how to get access + the OAuth refresh token.
GOOGLE_REVIEWS_ENABLED=false

# Google Cloud OAuth client (scope: https://www.googleapis.com/auth/business.manage)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token

# Optional: pin one GBP account ("accounts/123456789"); blank = auto-discover all.
GBP_ACCOUNT_ID=

# Chatwoot API-channel inbox id for reviews. Create it with:
#   python setup_google_reviews.py
REVIEWS_INBOX_ID=0
# Team for handed-off (negative) reviews; blank = falls back to TEAM_ID_SUPPORT.
REVIEWS_TEAM_ID=

# Poller cadence + auto-reply policy
REVIEWS_POLL_INTERVAL_SECONDS=300
REVIEWS_AUTO_REPLY=true
# Reviews with fewer stars than this are ALWAYS handed to a human (never auto).
REVIEWS_AUTO_REPLY_MIN_STARS=4

# ── Spam-classifier safeguards (OPTIONAL — sensible defaults) ──────────────
# Inboxes (by name, lowercase, comma-separated) that bypass the spam
# classifier entirely. Anything landing here is always treated as legitimate.
# For inboxes where a mis-classification would cost money / legal exposure.
NEVER_SPAM_INBOXES=legal-notices,complaints,abuse-reports,escalations

# Minimum classifier confidence (1-10) to AUTO-SNOOZE a spam conversation.
# Below this, "spam" label still applies but the conversation stays Open
# so a human can verify. Default 8 = high bar.
SPAM_CONFIDENCE_THRESHOLD=8

# Prior NON-spam conversations a sender needs for the low-confidence-spam
# tiebreaker to downgrade their message to 'promotional'. NOT a bypass —
# high-confidence spam from a known sender still gets snoozed.
WHITELIST_MIN_PRIOR_CONVERSATIONS=1

# Conversation ID to drop the spam-review digest into. 0 disables auto-post
# (you can still hit /spam-digest manually for the JSON list).
SPAM_DIGEST_INBOX_ID=0

# Shared secret guarding the /spam-digest endpoint. Required (fail-closed)
# — without this set, /spam-digest returns 503. Send it as `X-Bridge-Token`
# header on every call. Generate with:  openssl rand -hex 32
BRIDGE_OPS_TOKEN=

# ── Priority-based SLA / auto-escalation (OPTIONAL) ────────────────────────
# When an agent flags a conversation with one of these priority levels, the
# bridge listens on `conversation_updated` and creates a Zoho Desk ticket
# with a dueDate computed from PRIORITY_SLA_HOURS.
PRIORITY_ESCALATION_LEVELS=urgent,high

# Per-priority reply-by SLA in hours. Comma-separated `level:hours` pairs.
# Defaults: urgent=1h, high=4h, medium=12h, low=24h
PRIORITY_SLA_HOURS=urgent:1,high:4,medium:12,low:24
